{
  "name": "sokoban-web",
  "private": true,
  "version": "2026.7.16",
  "type": "module",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "npm run lint && vite build",
    "gen:levels": "tsc -p tsconfig.scripts.json && node dist-scripts/scripts/gen-levels.js",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "npm test",
    "coverage": "vitest run --coverage",
    "test:coverage": "npm run coverage",
    "check": "npm run format && npm run build && npm run coverage"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.0.18",
    "prettier": "^3.9.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vitest": "^4.0.18"
  }
}
